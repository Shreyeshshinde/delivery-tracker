# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/delivery_tracker

# Redis (Celery broker + outbox queue)
REDIS_URL=redis://localhost:6379/0

# JWT auth
SECRET_KEY=change-this-to-a-random-64-char-string-before-deploying
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email (fill in during Phase 5 - notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# SMS (fill in during Phase 5 - notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# App
ENVIRONMENT=development